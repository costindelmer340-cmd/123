            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"退款多久到账？\",\n  \"answer\": \"一般以平台退款进度为准。\",\n  \"category\": \"REFUND\"\n}"
            },
            "url": "{{base_url}}/api/merchant/knowledge/faqs/1"

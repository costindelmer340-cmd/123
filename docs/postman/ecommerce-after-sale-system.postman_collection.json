            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"手机类商品售后检查标准\",\n  \"category\": \"PRODUCT_POLICY\",\n  \"content\": \"收到质量问题反馈后，优先核验照片、序列号和签收时间。\"\n}"
            },
            "url": "{{base_url}}/api/merchant/knowledge/articles"
          }
        },
        {
          "name": "修改知识文章",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"手机类商品售后检查标准\",\n  \"category\": \"PRODUCT_POLICY\",\n  \"content\": \"更新后的售后检查标准。\"\n}"
            },
            "url": "{{base_url}}/api/merchant/knowledge/articles/1"
          }
        },
        {
          "name": "删除知识文章",
          "request": {

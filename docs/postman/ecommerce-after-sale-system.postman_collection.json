            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ruleName\": \"质量问题优先审核\",\n  \"ruleType\": \"PRIORITY\",\n  \"content\": \"质量问题进入人工复核队列。\"\n}"
            },
            "url": "{{base_url}}/api/merchant/knowledge/rules/1"

page {
  background: #f6f8fb;
  color: #172033;
  font-family: -apple-system, BlinkMacSystemFont, "Microsoft YaHei", sans-serif;
}

.page {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.muted {
  color: #667085;
  font-size: 26rpx;
}

.primary-btn {
  margin-top: 20rpx;
  background: #1f7ae0;
  color: #fff;
}

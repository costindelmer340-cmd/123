.page-title {
  font-size: 38rpx;
  font-weight: 800;
  margin: 8rpx 0 24rpx;
}

.order-card {
  display: flex;
  background: #ffffff;
  border: 1rpx solid #eef2f7;
  border-radius: 18rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.product-thumb {
  width: 150rpx;
  height: 150rpx;
  border-radius: 18rpx;
  background: #eaf2ff;
  margin-right: 22rpx;
  flex-shrink: 0;
}

.order-info {
  flex: 1;
  min-width: 0;
}

.order-title {
  font-size: 31rpx;
  font-weight: 800;
  color: #101828;
  max-width: 310rpx;
}

.price {
  color: #1f7ae0;
  font-weight: 700;
}

.order-bottom {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-link {
  color: #1f7ae0;
  font-size: 24rpx;
}

.empty-card {
  background: #ffffff;
  border: 1rpx solid #eef2f7;
  border-radius: 18rpx;
  padding: 42rpx 28rpx;
  text-align: center;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #101828;
  margin-bottom: 12rpx;
}

.empty-text {
  color: #667085;
  font-size: 26rpx;
  line-height: 1.6;
  margin-bottom: 28rpx;
}

.empty-btn {
  width: 220rpx;
  background: #1f7ae0;
  color: #ffffff;
  border-radius: 14rpx;
  font-size: 28rpx;
}

.source-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #eaf3ff;
  border: 1rpx solid #cfe2ff;
  border-radius: 16rpx;
  padding: 18rpx 22rpx;
  margin: 12rpx 0 18rpx;
}

.source-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #0f3f86;
}

.source-account {
  font-size: 24rpx;
  color: #315d9b;
}

.empty-mini {
  color: #667085;
  background: #ffffff;
  border: 1rpx solid #eef2f7;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
}
